{
    "name": "react-app",
    "version": "0.0.1",
    "private": true,
    "scripts": {
        "start": "max dev",
        "start:menu": "cross-env MENU=1 max dev",
        "build": "cross-env UMI_ENV=prod max build",
        "build:bad": "cross-env UMI_ENV=prod FONT_SIZE_BASE=12 max build ",
        "build:noCompress": "cross-env UMI_ENV=prod COMPRESS=none max build",
        "build:analyze": "cross-env UMI_ENV=prod ANALYZE=1 max build",
        "prettier": "prettier --write \"src/**/*+(js|less|css|jsx)\"",
        "prettier:check": "prettier --check \"src/**/*+(js|less|css|jsx)\"",
        "pretty-quick": "pretty-quick",
        "lint": "npm run lint:script",
        "lint:script": "eslint --ext .js --ext jsx src",
        "lintfix:style": "stylelint src/**/*.{less,css} --fix",
        "release": "release-it --no-npm.publish",
        "version": "npm run changelog && git add CHANGELOG.md",
        "changelog": "conventional-changelog -p custom-config -i CHANGELOG.md -s -r 0",
        "g-page": "max g page",
        "postinstall": "node ./scripts/cesium-fix.js",
        "p2md": "babel-node --presets @babel/preset-env ./scripts/generate"
    },
    "husky": {
        "hooks": {
            "pre-commit": "lint-staged",
            "commit-msg": "commitlint -E HUSKY_GIT_PARAMS"
        }
    },
    "lint-staged": {
        "src/**/*.{js,jsx,less,md,json}": [
            "npm run prettier:check"
        ],
        "src/**/*+(js|jsx)": "npm run lint"
    },
    "release-it": {
        "git": {
            "commitMessage": "chore: release v${version}"
        }
    },
    "changelog": {
        "emojis": true,
        "authorName": true
    },
    "dependencies": {
        "@ant-design/icons": "^6.0.0",
        "@vtx/components": "^4.0.0-beta.45",
        "@vtx/map": "^2.0.0-beta.1",
        "@vtx/sdk": "^1.1.2",
        "@vtx/utils": "^1.0.7",
        "ahooks": "^3.9.6",
        "antd": "^6.0.0",
        "axios": "^1.6.0",
        "classnames": "^2.5.0",
        "dayjs": "^1.11.10",
        "echarts": "^5.4.3",
        "echarts-for-react": "^3.0.2",
        "@vtx/ol-map": "^2.0.0-beta.3",
        "ol": "6.15.1",
        "@vtx/map-icon": "^2.0.59",
        "lodash-es": "^4.17.21",
        "react": "^18.0.0",
        "react-dom": "^18.0.0",
        "react-redux": "^9.2.0",
        "updeep": "^1.2.4"
    },
    "devDependencies": {
        "@umijs/max": "^4.0.90",
        "@babel/node": "^7.22.19",
        "@babel/preset-env": "^7.23.6",
        "@commitlint/cli": "^11.0.0",
        "@commitlint/config-conventional": "^11.0.0",
        "@eslint/js": "^9.39.2",
        "@testing-library/jest-dom": "^5",
        "@testing-library/react": "^14",
        "@types/jest": "^29",
        "@types/mockjs": "^1.0.10",
        "@types/react": "^18.0.33",
        "@types/react-dom": "^18.0.11",
        "@types/testing-library__jest-dom": "^5.14.5",
        "autoprefixer": "^10.4.24",
        "conventional-changelog-cli": "^2.1.1",
        "conventional-changelog-custom-config": "^0.3.1",
        "cross-env": "^7.0.2",
        "eslint": "^9.39.2",
        "eslint-plugin-react": "^7.37.5",
        "globals": "^17.3.0",
        "husky": "^4.3.8",
        "jest": "^29",
        "jest-environment-jsdom": "^29",
        "lint-staged": "^10.0.7",
        "mockjs": "^1.1.0",
        "prettier": "^2.8.8",
        "postcss": "^8.5.6",
        "postcss-styled-syntax": "^0.7.1",
        "pretty-quick": "^3.1.3",
        "ts-node": "^10",
        "typescript": "^5.3.3",
        "i18next": "^23.7.8",
        "react-i18next": "^13.5.0",
        "release-it": "^14.4.1",
        "stylelint": "^13.12.0",
        "stylelint-config-prettier": "^8.0.2",
        "stylelint-config-rational-order": "^0.1.2",
        "stylelint-config-standard": "^21.0.0",
        "stylelint-declaration-block-no-ignored-properties": "^2.3.0",
        "stylelint-order": "^4.1.0",
        "tailwindcss": "^3.4.19",
        "qs": "^6.14.1"
    }
}